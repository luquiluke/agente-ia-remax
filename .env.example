# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ─── ReMax Credenciales (para scraping autenticado) ───────────────────────────
REMAX_EMAIL=agente@remax.com.ar
REMAX_PASSWORD=tu_contraseña

# ─── Configuración ReMax ──────────────────────────────────────────────────────
REMAX_TABLA=0.60              # % del bruto que retiene el agente (ej: 0.60 = tabla 60%)
COMISION_BRUTA_PCT=0.04       # % de comisión total sobre precio de venta (ej: 0.04 = 4%)

# ─── Tipo de cambio ───────────────────────────────────────────────────────────
TC_BLUE=1250                  # ARS por USD (dólar blue/informal)
TC_OFICIAL=1100               # ARS por USD (oficial BNA)

# ─── Google Sheets (opcional — la app corre en modo demo sin estas) ───────────
GOOGLE_SHEETS_CREDENTIALS=credentials/service_account.json
GOOGLE_SPREADSHEET_ID=
PROPIEDADES_SHEET=propiedades
DEALS_SHEET=deals
CLIENTES_SHEET=clientes

# ─── Gmail SMTP (opcional) ────────────────────────────────────────────────────
GMAIL_ADDRESS=tu@gmail.com
GMAIL_APP_PASSWORD=          # App Password de Gmail (no la contraseña normal)
REPORT_RECIPIENT_EMAIL=      # Email destino del reporte diario

# ─── Google Calendar (opcional) ───────────────────────────────────────────────
GOOGLE_CALENDAR_ID=primary

# ─── Scanner ─────────────────────────────────────────────────────────────────
SCANNER_MAX_PROPIEDADES=50
SCANNER_PRECIO_MIN_USD=50000
SCANNER_PRECIO_MAX_USD=500000

# ─── Contraseña modo agente interno ──────────────────────────────────────────
INTERNAL_PASSWORD=remax2026
